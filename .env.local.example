# ─────────────────────────────────────────────────────────────
# LASTPROOF — local dev environment template
# Copy to .env.local and fill in. Never commit .env.local.
# Dev server runs on port 3001 (Terminal dev uses 3000 — do not collide).
# ─────────────────────────────────────────────────────────────

# --- Supabase (lastproof project — NOT shared with Terminal) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Terminal S2S bridge ---
# Local dev: point at the in-app mock route.
# Staging:   https://staging.lastshift.app
# Prod:      https://lastshift.app
TERMINAL_API_URL=http://localhost:3001/api/mock/terminal
INTER_TOOL_API_SECRET=dev-mock-secret-not-for-production
INTER_TOOL_KEY_ID=v1

# --- Tool identity ---
TOOL_SLUG=lastproof

# --- Solana / Helius (LASTPROOF owns its own Helius project) ---
HELIUS_RPC_URL=
HELIUS_WEBHOOK_SECRET=
LASTSHFT_MINT=5zHrdYRtUzjkQwnq6HkS6Vq7KCeEQPysmaUmwKqfFLqB
LASTPROOF_AR_WALLET=

# --- SHIFTBOT (LASTPROOF's own instance, separate Groq key) ---
LASTPROOF_GROQ_API_KEY=

# --- Feature flags ---
PAYMENTS_ENABLED=false
GRID_LAUNCH_DATE=2026-05-08T00:00:00Z
