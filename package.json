{
  "name": "lastproof",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/mirror-blog-images.mjs",
    "dev": "next dev -p 3001",
    "prebuild": "node scripts/mirror-blog-images.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/unit/*.test.ts tests/integration/*.test.ts",
    "test:dual": "LASTPROOF_DB_QUOTES=dual LASTPROOF_DB_PAYMENTS=dual LASTPROOF_DB_PROFILES=dual LASTPROOF_DB_PROOFS=dual LASTPROOF_DB_NOTIFICATIONS=dual LASTPROOF_DB_HANDLE_HISTORY=dual node --import tsx --test --test-concurrency=1 tests/integration/*-dual-write.test.ts",
    "verify:lastshft": "tsx scripts/verify-lastshft-mint.ts",
    "soak": "tsx scripts/soak-dual-write.ts"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-wallets": "^0.19.38",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.102.1",
    "gray-matter": "^4.0.3",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reading-time": "^1.5.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  }
}
