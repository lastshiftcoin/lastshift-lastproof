{
  "framework": "nextjs",
  "rewrites": [
    { "source": "/((?!api|_next|maintenance\\.html|favicon\\.ico|robots\\.txt|sitemap\\.xml|tokens|avatars|.*\\.png|.*\\.jpg|.*\\.svg).*)", "destination": "/maintenance.html" }
  ],
  "crons": [
    {
      "path": "/api/subscription/cron",
      "schedule": "5 0 * * *"
    },
    {
      "path": "/api/affiliate/worker",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/proof/verify-tx/process",
      "schedule": "* * * * *"
    }
  ]
}
